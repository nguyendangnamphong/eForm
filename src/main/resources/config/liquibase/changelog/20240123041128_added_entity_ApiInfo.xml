        <property name="autoIncrement" value="true"/>

    <!--
        Added the entity ApiInfo.
    -->
    <changeSet id="20240123041128-1" author="jhipster">
        <createTable tableName="api_info">
            <column name="id" type="bigint" autoIncrement="${autoIncrement}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="domain" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="path" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="header" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="request" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="response_api" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="created_by" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="created_date" type="datetime">
                <constraints nullable="true" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
        <dropDefaultValue tableName="api_info" columnName="created_date" columnDataType="datetime"/>
    </changeSet>

    <changeSet id="20240123041128-1-relations" author="jhipster">

    </changeSet>

    <changeSet id="change_type_apiId" author="ducnv88">
        <sql>ALTER TABLE api_info MODIFY id varchar(255);</sql>
    </changeSet>
