<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.9.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

        <property name="autoIncrement" value="true"/>

    <!--
        Added the entity VariableSystemAcl.
    -->
    <changeSet id="20251015081159-1" author="jhipster">
        <createTable tableName="variable_system_acl">
            <column name="id" type="bigint" autoIncrement="${autoIncrement}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="var_id" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="perm" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="perm_type" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="assignee_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="assignee" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="authorizer_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="authorizer" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="created_by" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="org_in" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="cust_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="created_date" type="datetime">
                <constraints nullable="true" />
            </column>
            <column name="last_modified_by" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="last_modified_date" type="datetime">
                <constraints nullable="true" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
        <dropDefaultValue tableName="variable_system_acl" columnName="created_date" columnDataType="datetime"/>
        <dropDefaultValue tableName="variable_system_acl" columnName="last_modified_date" columnDataType="datetime"/>
    </changeSet>

    <changeSet id="20251015081159-1-relations" author="jhipster">

    </changeSet>
